import os
import json
from functools import lru_cache
from typing import List, Optional, Union

from pydantic import Field, field_validator
from pydantic_settings import BaseSettings


class Settings(BaseSettings):
    app_name: str = "QuantumForge AI"
    debug: bool = Field(default=False, env="DEBUG")
    
    # Multi-Provider LLM Configuration - handles both JSON and comma-separated strings
    llm_providers: List[str] = Field(
        default=["openai", "groq", "fallback"],
        env="LLM_PROVIDERS"
    )
    llm_routing_strategy: str = Field(
        default="priority",  # priority, round_robin, load_balance
        env="LLM_ROUTING_STRATEGY"
    )
    
    # OpenAI Configuration
    openai_api_key: Optional[str] = Field(default=None, env="OPENAI_API_KEY")
    openai_base_url: str = Field(default="https://api.openai.com/v1", env="OPENAI_BASE_URL")
    openai_model: str = Field(default="gpt-4", env="OPENAI_MODEL")
    openai_timeout: int = Field(default=60, env="OPENAI_TIMEOUT")
    openai_max_tokens: int = Field(default=2000, env="OPENAI_MAX_TOKENS")
    openai_temperature: float = Field(default=0.7, env="OPENAI_TEMPERATURE")
    openai_priority: int = Field(default=1, env="OPENAI_PRIORITY")
    
    # Groq Configuration
    groq_api_key: Optional[str] = Field(default=None, env="GROQ_API_KEY")
    groq_model: str = Field(default="mixtral-8x7b-32768", env="GROQ_MODEL")
    groq_timeout: int = Field(default=30, env="GROQ_TIMEOUT")
    groq_max_tokens: int = Field(default=2000, env="GROQ_MAX_TOKENS")
    groq_temperature: float = Field(default=0.7, env="GROQ_TEMPERATURE")
    groq_priority: int = Field(default=2, env="GROQ_PRIORITY")
    
    # Anthropic Configuration
    anthropic_api_key: Optional[str] = Field(default=None, env="ANTHROPIC_API_KEY")
    anthropic_model: str = Field(default="claude-3-opus-20240229", env="ANTHROPIC_MODEL")
    anthropic_timeout: int = Field(default=60, env="ANTHROPIC_TIMEOUT")
    anthropic_max_tokens: int = Field(default=2000, env="ANTHROPIC_MAX_TOKENS")
    anthropic_temperature: float = Field(default=0.7, env="ANTHROPIC_TEMPERATURE")
    anthropic_priority: int = Field(default=3, env="ANTHROPIC_PRIORITY")
    
    # Local/Offline Model Configuration
    local_model_path: Optional[str] = Field(default=None, env="LOCAL_MODEL_PATH")
    local_model_type: str = Field(default="llama_cpp", env="LOCAL_MODEL_TYPE")
    local_context_length: int = Field(default=4096, env="LOCAL_CONTEXT_LENGTH")
    local_priority: int = Field(default=99, env="LOCAL_PRIORITY")
    
    # Fallback Configuration
    enable_fallback_mock: bool = Field(default=True, env="ENABLE_FALLBACK_MOCK")
    
    # Global LLM Defaults
    default_temperature: float = Field(default=0.7, env="DEFAULT_TEMPERATURE")
    default_max_tokens: int = Field(default=2000, env="DEFAULT_MAX_TOKENS")
    default_timeout: int = Field(default=60, env="DEFAULT_TIMEOUT")
    max_retries_per_provider: int = Field(default=2, env="MAX_RETRIES_PER_PROVIDER")
    
    # Memory Configuration
    vector_store_path: str = Field(default="./data/vector_store", env="VECTOR_STORE_PATH")
    embedding_dim: int = Field(default=384, env="EMBEDDING_DIM")
    max_memory_items: int = Field(default=1000, env="MAX_MEMORY_ITEMS")
    
    # Sandbox Configuration
    sandbox_timeout: int = Field(default=30, env="SANDBOX_TIMEOUT")
    sandbox_max_memory_mb: int = Field(default=512, env="SANDBOX_MAX_MEMORY_MB")
    
    # Distributed Configuration
    ray_address: Optional[str] = Field(default=None, env="RAY_ADDRESS")
    max_parallel_workers: int = Field(default=4, env="MAX_PARALLEL_WORKERS")
    
    # Evolution Configuration
    evolution_population_size: int = Field(default=5, env="EVOLUTION_POPULATION_SIZE")
    evolution_mutation_rate: float = Field(default=0.3, env="EVOLUTION_MUTATION_RATE")
    
    # Logging
    log_level: str = Field(default="INFO", env="LOG_LEVEL")
    log_format: str = Field(default="json", env="LOG_FORMAT")
    
    @field_validator('llm_providers', mode='before')
    @classmethod
    def parse_llm_providers(cls, v):
        """Parse LLM_PROVIDERS from string or list"""
        if isinstance(v, str):
            # Handle empty string
            if not v or v.strip() == '':
                return ["fallback"]
            # Try JSON first (for '["openai", "groq"]' format)
            try:
                parsed = json.loads(v)
                if isinstance(parsed, list):
                    return parsed
            except json.JSONDecodeError:
                # Fall back to comma-separated (for 'openai,groq,fallback' format)
                return [item.strip() for item in v.split(',') if item.strip()]
        elif isinstance(v, list):
            return v
        return ["fallback"]
    
    class Config:
        env_file = ".env"
        case_sensitive = False
        # Allow extra fields for flexibility
        extra = 'ignore'


@lru_cache()
def get_settings() -> Settings:
    return Settings()


settings = get_settings()
